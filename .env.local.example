# ─────────────────────────────────────────────────────────────
#  Copy this file to ".env.local" and fill in your real values.
#  In Vercel, add these same keys under Project Settings → Environment Variables.
#  All variables MUST start with VITE_ or Vite will ignore them.
# ─────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# --- Password gate (people must type this to enter) ---
VITE_APP_PASSWORD=loveyou28

# --- Customizable text (optional — has sensible defaults) ---
VITE_BIRTHDAY_NAME=Beautiful
VITE_BIRTHDAY_AGE=28
VITE_GREETING=Happy 28th Birthday!
VITE_SUBTITLE=A little garden of our memories, always growing 🌸

# Shown on the landing page BEFORE the gift box appears.
VITE_INTRO=Someone loves you very much 💗

# Set to "false" to disable the password screen entirely.
VITE_PASSWORD_ENABLED=true
